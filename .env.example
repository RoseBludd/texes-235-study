# PostgreSQL connection string (required for API and seed).
# Optional: isolate tables in a dedicated schema on a shared Neon DB (recommended if
# another app uses the same DATABASE_URL on public). Then run: npm run db:setup && npm run db:seed
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
POSTGRES_SCHEMA=texes235

# Optional: canonical site URL for Open Graph / link previews (default is Vercel production URL).
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
